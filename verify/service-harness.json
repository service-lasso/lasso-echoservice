{
  "serviceId": "echo-service",
  "health": {
    "type": "process",
    "timeoutSeconds": 30
  },
  "expect": {
    "logs": true,
    "state": true,
    "sqlite": true,
    "exitClean": true
  },
  "api": {
    "endpoints": [
      "/health",
      "/state",
      "/logs",
      "/sqlite"
    ],
    "actions": [
      "write-log",
      "write-state",
      "write-sqlite",
      "error",
      "fork-child",
      "start-child"
    ]
  },
  "artifacts": {
    "captureLogs": true,
    "captureState": true,
    "captureSummary": true
  }
}
