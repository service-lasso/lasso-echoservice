{
  "serviceId": "echo-service",
  "health": {
    "type": "process",
    "timeoutSeconds": 30
  },
  "expect": {
    "logs": true,
    "state": true,
    "sqlite": true,
    "stdout": true,
    "stderr": true,
    "exitClean": true
  },
  "api": {
    "endpoints": [
      "/health",
      "/health/http",
      "/health/tcp",
      "/state",
      "/logs",
      "/sqlite",
      "/env",
      "/global-env",
      "/service-lasso/output"
    ],
    "actions": [
      "write-log",
      "write-state",
      "write-sqlite",
      "write-stdout",
      "write-stderr",
      "http-health",
      "tcp-health",
      "error",
      "fork-child",
      "start-child"
    ]
  },
  "artifacts": {
    "captureLogs": true,
    "captureState": true,
    "captureSummary": true
  }
}
